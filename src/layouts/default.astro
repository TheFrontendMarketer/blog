---
import Navbar from "../components/Navbar.astro";
import Footer from "../../src/components/Footer.astro";
import "../styles/global.css";
const { title } = Astro.props;
const { description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-MS6Q7ZZ8");
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={description ||
        "The Frontend Marketer is a blog about digital marketing and frontend web development."}
    />
    <title>{title || "The Frontend Marketer"}</title>
    <link rel="icon" type="image/svg+xml" href="/tfm_favicon.png" />
  </head>
  <body class={Astro.props.bodyClass}>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MS6Q7ZZ8"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <header>
      <Navbar />
    </header>
    <main class="siteContainer">
      <slot />
    </main>
    <footer>
      <Footer />
    </footer>
  </body>
</html>
